# Common Spring profile
SPRING_PROFILES_ACTIVE=local

# Service port. Render also sets PORT automatically; the app supports both.
SERVER_PORT=8080

# Database. Local defaults use MySQL. Render may provide postgresql:// through DATABASE_URL.
DATABASE_URL=jdbc:postgresql://localhost:5432/payment_db
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=postgres

# Local MySQL fallbacks for individual services
MYSQL_USER=root
MYSQL_PASSWORD=root123
AUTH_DB_URL=jdbc:mysql://localhost:3306/payment_auth_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
TRANSACTION_DB_URL=jdbc:mysql://localhost:3306/payment_transaction_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
RECONCILIATION_DB_URL=jdbc:mysql://localhost:3306/payment_reconciliation_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
NOTIFICATION_DB_URL=jdbc:mysql://localhost:3306/payment_notification_db?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# Security
JWT_SECRET=change-this-secret-to-a-very-long-256-bit-key-for-prod
JWT_EXPIRATION_MS=7200000
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:5173,http://localhost:3000,https://*.vercel.app,https://*.netlify.app
FRONTEND_URL=http://localhost:5173
PUBLIC_BASE_URL=http://localhost:8080

# Service discovery and direct URLs
EUREKA_ENABLED=true
EUREKA_URL=http://localhost:8761/eureka
AUTH_SERVICE_URL=http://localhost:8081
TRANSACTION_SERVICE_URL=http://localhost:8082
FRAUD_SERVICE_URL=http://localhost:8083
RECONCILIATION_SERVICE_URL=http://localhost:8084
NOTIFICATION_SERVICE_URL=http://localhost:8085
REPORTING_SERVICE_URL=http://localhost:8086

# Optional infrastructure. Free deployment keeps these disabled.
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
REDIS_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
MONGODB_ENABLED=false
MONGODB_URI=mongodb://localhost:27017/fraud_db

